@model IEnumerable<SistemaSuscripciones.Entities.Cliente>

@{
    ViewData["Title"] = "Clientes";
}

<div class="container mt-4">
    @if (TempData["Exito"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert" id="alertaExito">
            <strong>¡Excelente!</strong> @TempData["Exito"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
            <strong>¡Atención!</strong> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
            <h4 class="mb-0">Gestión de Clientes</h4>
            <a asp-action="Crear" class="btn btn-outline-light btn-sm">Nuevo Cliente</a>
        </div>
        <div class="card-body">
            <table class="table table-hover table-bordered">
                <thead class="table-light">
                    <tr>
                        <th>Nombres</th>
                        <th>Apellidos</th>
                        <th>Documento</th>
                        <th>Teléfono</th>
                        <th>Correo</th>
                        <th>Registro</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Nombres</td>
                            <td>@item.Apellidos</td>
                            <td>@item.DocumentoIdentidad</td>
                            <td>@item.Telefono</td>
                            <td>@item.Correo</td>
                            <td>@item.FechaRegistro.ToString("dd/MM/yyyy")</td>
                            <td>
                                <a asp-action="Editar" asp-route-id="@item.Id" class="btn btn-info btn-sm text-white fw-bold">Editar</a>

                                <form asp-action="Eliminar" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('¿Está seguro de que desea desactivar a este cliente?');">
                                    <button type="submit" class="btn btn-danger btn-sm fw-bold">Eliminar</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    @section Scripts {
        <script>
            $(document).ready(function () {
                setTimeout(function () {
                    $("#alertaExito").fadeOut("slow", function () {
                        $(this).remove();
                    });
                }, 3000);
            });
        </script>
    }
</div>
