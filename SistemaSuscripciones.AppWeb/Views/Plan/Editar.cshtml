@model SistemaSuscripciones.Entities.Plan

@{
    ViewData["Title"] = "Editar Plan";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0">Editar Plan</h5>
                </div>
                <div class="card-body">
                    <form asp-action="Editar" method="post">
                        <input type="hidden" asp-for="Id" />

                        <div class="mb-3">
                            <label class="form-label fw-bold">Nombre del Plan</label>
                            <input asp-for="Nombre" class="form-control" required />
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Precio ($)</label>
                                <input asp-for="Precio" class="form-control" type="number" step="0.01" min="0.01" required />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Duración (Meses)</label>
                                <input asp-for="DuracionMeses" class="form-control" type="number" min="1" required />
                            </div>
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-4">
                            <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
                            <button type="submit" class="btn btn-info text-white fw-bold">Actualizar Plan</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
