@model IEnumerable<SistemaSuscripciones.Entities.Pago>

@{
    ViewData["Title"] = "Pagos";
}

<div class="container mt-4">
    @if (TempData["Exito"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert" id="alertaExito">
            <strong>¡Excelente!</strong> @TempData["Exito"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
            <strong>¡Atención!</strong> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
            <h4 class="mb-0">Registro de Pagos</h4>
            <a asp-action="Registrar" class="btn btn-outline-light btn-sm">Nuevo Pago</a>
        </div>
        <div class="card-body">
            <table class="table table-hover table-bordered">
                <thead class="table-light">
                    <tr>
                        <th>Cliente</th>
                        <th>Plan</th>
                        <th>Monto</th>
                        <th>Fecha</th>
                        <th>Método</th>
                        <th>Referencia</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.ClienteNombre</td>
                            <td>@item.NombrePlan</td>
                            <td>$@item.Monto.ToString("N2")</td>
                            <td>@item.FechaPago.ToString("dd/MM/yyyy")</td>
                            <td>
                                @if (item.MetodoPago == "Efectivo")
                                {
                                    <span class="badge bg-success">@item.MetodoPago</span>
                                }
                                else if (item.MetodoPago == "Transferencia")
                                {
                                    <span class="badge bg-primary">@item.MetodoPago</span>
                                }
                                else
                                {
                                    <span class="badge bg-info text-dark">@item.MetodoPago</span>
                                }
                            </td>
                            <td>@(string.IsNullOrEmpty(item.Referencia) ? "—" : item.Referencia)</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    @section Scripts {
        <script>
            $(document).ready(function () {
                setTimeout(function () {
                    $("#alertaExito").fadeOut("slow", function () {
                        $(this).remove();
                    });
                }, 3000);
            });
        </script>
    }
</div>
