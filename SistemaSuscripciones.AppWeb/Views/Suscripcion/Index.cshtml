@model IEnumerable<SistemaSuscripciones.Entities.Suscripcion>

@{
    ViewData["Title"] = "Suscripciones";
}

<div class="container mt-4">
    @if (TempData["Exito"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert" id="alertaExito">
            <strong>¡Excelente!</strong> @TempData["Exito"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
            <strong>¡Atención!</strong> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    <div class="card shadow-sm">
        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
            <h4 class="mb-0">Control de Suscripciones</h4>
            <a asp-action="Crear" class="btn btn-outline-light btn-sm">Nueva Suscripción</a>
        </div>
        <div class="card-body">
            <table class="table table-hover table-bordered">
                <thead class="table-light">
                    <tr>
                        <th>Cliente</th>
                        <th>Documento</th>
                        <th>Plan</th>
                        <th>Fecha Fin</th>
                        <th>Estado</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.ClienteNombre</td>
                            <td>@item.DocumentoIdentidad</td>
                            <td>@item.NombrePlan</td>
                            <td>@item.FechaFin.ToString("dd/MM/yyyy")</td>
                            <td>
                                @if (item.Estado == "Activo")
                                {
                                    <span class="badge bg-success">@item.Estado</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">@item.Estado</span>
                                }
                            </td>
                            <td>
                                <a asp-action="Renovar" asp-route-id="@item.Id" class="btn btn-warning btn-sm text-dark fw-bold">Renovar</a>

                                <form asp-action="Anular" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('¿Está seguro de que desea anular esta suscripción?');">
                                    <button type="submit" class="btn btn-danger btn-sm fw-bold">Anular</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    @section Scripts {
        <script>
            // Este código hace que la alerta de éxito desaparezca suavemente después de 3 segundos
            $(document).ready(function () {
                setTimeout(function () {
                    $("#alertaExito").fadeOut("slow", function () {
                        $(this).remove();
                    });
                }, 3000); // 3000 milisegundos = 3 segundos
            });
        </script>
    }
</div>